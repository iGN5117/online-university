# Anthropic — required for the Course Builder / teacher / deepen agents
ANTHROPIC_API_KEY=
# Optional: override the agent model (defaults to claude-haiku-4-5)
# AGENT_MODEL=claude-haiku-4-5

# Auth.js (NextAuth v5) — Google sign-in
# Generate a secret with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=
# Google OAuth client (Google Cloud Console → Credentials → OAuth client ID).
# Authorized redirect URI: <origin>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Public origin of the app (e.g. https://online-university.fly.dev). Optional
# in dev; required in production for correct OAuth callback URLs.
# AUTH_URL=

# Invite-only access: comma-separated list of allowed Google emails.
ALLOWED_EMAILS=you@example.com
# The owner adopts any pre-existing (NULL-owned) content on login — set this to
# your email when migrating an existing single-tenant database.
OWNER_EMAIL=you@example.com

# Deployment: directory for the SQLite database (mounted persistent volume).
# DB_DIR=/data
